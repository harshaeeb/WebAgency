---
// src/components/Footer.astro
import { site } from "../config/site";

const year = new Date().getFullYear();
const mapsQuery = encodeURIComponent(site.address);
const isBrand = site.theme?.footerStyle === "brand";
const tagline = site.footerTagline ?? site.tagline;
---

<footer class={isBrand ? "bg-[var(--brand-900)] text-[var(--brand-200)] mt-auto" : "bg-slate-900 text-slate-300 mt-auto"}>
  <!-- Accent line -->
  <div class={`h-1 w-full ${isBrand ? "bg-gradient-to-r from-[var(--brand-500)] to-[var(--brand-700)]" : "bg-gradient-to-r from-[var(--brand-600)] to-[var(--brand-400)]"}`}></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 grid grid-cols-1 md:grid-cols-3 gap-10">

    <!-- Brand column -->
    <div>
      <div class="flex items-center gap-2.5 mb-3">
        <span class="w-8 h-8 rounded-lg bg-[var(--brand-700)] flex items-center justify-center text-white text-sm font-black flex-shrink-0">
          {site.business.charAt(0)}
        </span>
        <p class="text-white font-bold text-lg">{site.business}</p>
      </div>
      <p class="text-sm opacity-55 leading-relaxed">{tagline}</p>
      <div class="mt-5 inline-flex items-center gap-2 rounded-full bg-white/5 border border-white/10 px-3.5 py-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-amber-400 flex-shrink-0">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
        </svg>
        <span class="text-xs text-white/60">{site.googleRating} · {site.googleReviewCount}+ Google reviews</span>
      </div>
    </div>

    <!-- Contact column -->
    <div>
      <p class="text-white font-semibold text-xs uppercase tracking-widest mb-5 opacity-60">Contact</p>
      <ul class="space-y-3.5 text-sm">
        <li>
          <a href={`tel:${site.phone}`} class="hover:text-white transition-colors flex items-center gap-2.5 group">
            <span class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--brand-700)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100">
                <path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511Z" clip-rule="evenodd" />
              </svg>
            </span>
            {site.phoneDisplay}
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="hover:text-white transition-colors flex items-center gap-2.5 group">
            <span class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--brand-700)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100">
                <path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 14H1.75A1.75 1.75 0 0 1 0 12.25v-8.5C0 2.784.784 2 1.75 2ZM1.5 5.854v6.396c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25V5.854L8.88 9.592a.75.75 0 0 1-.76 0L1.5 5.854Zm.63-2.354 5.87 3.54L13.87 3.5H2.13Z" />
              </svg>
            </span>
            {site.email}
          </a>
        </li>
        <li>
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors flex items-start gap-2.5 group"
          >
            <span class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center flex-shrink-0 mt-0.5 group-hover:bg-[var(--brand-700)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100">
                <path fill-rule="evenodd" d="M8 1a5 5 0 0 0-5 5c0 3.536 4.24 8.3 4.762 8.87a.329.329 0 0 0 .476 0C8.76 14.3 13 9.536 13 6a5 5 0 0 0-5-5Zm0 6.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" clip-rule="evenodd" />
              </svg>
            </span>
            {site.address}
          </a>
        </li>
      </ul>
    </div>

    <!-- Service areas column -->
    <div>
      <p class="text-white font-semibold text-xs uppercase tracking-widest mb-5 opacity-60">Service Areas</p>
      <div class="flex flex-wrap gap-2">
        {site.serviceAreas.map((area) => (
          <span class="text-xs px-2.5 py-1 rounded-full bg-white/8 border border-white/10 text-white/60 hover:text-white/80 hover:bg-white/12 transition-colors">
            {area}
          </span>
        ))}
      </div>
    </div>
  </div>

  <div class={`border-t py-5 px-4 sm:px-6 max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-xs opacity-35 ${
    isBrand ? "border-[var(--brand-800)]" : "border-slate-800"
  }`}>
    <p>&copy; {year} {site.business}. All rights reserved.</p>
    <p>Website by <a href="#" class="hover:opacity-70 transition-opacity">[Your Agency Name]</a></p>
  </div>
</footer>
