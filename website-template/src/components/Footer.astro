---
// src/components/Footer.astro
import { site } from "../config/site";

const year = new Date().getFullYear();
const mapsQuery = encodeURIComponent(site.address);
---

<footer class="bg-slate-900 text-slate-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <p class="text-white font-semibold text-lg">{site.business}</p>
      <p class="mt-2 text-sm text-slate-400">{site.tagline}</p>
    </div>

    <div>
      <p class="text-white font-semibold text-sm uppercase tracking-wide mb-3">Contact</p>
      <ul class="space-y-2 text-sm">
        <li>
          <a href={`tel:${site.phone}`} class="hover:text-white transition-colors">
            {site.phoneDisplay}
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">
            {site.email}
          </a>
        </li>
        <li>
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors"
          >
            {site.address}
          </a>
        </li>
      </ul>
    </div>

    <div>
      <p class="text-white font-semibold text-sm uppercase tracking-wide mb-3">Service Areas</p>
      <p class="text-sm text-slate-400">{site.serviceAreas.join(" \u00B7 ")}</p>
    </div>
  </div>

  <div class="border-t border-slate-800 py-5 px-4 sm:px-6 max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-500">
    <p>&copy; {year} {site.business}. All rights reserved.</p>
    <!--
      Agency credit per the services contract (Section 7 / Ownership & IP):
      "The Service Provider may display the completed Website in its
      portfolio and add a discreet 'Website by [agency]' credit in the
      footer unless the Client opts out in writing."
      Replace [Your Agency Name] and the link below with your actual
      agency details, or remove this line entirely if a client opts out.
    -->
    <p>
      Website by <a href="#" class="hover:text-slate-300 transition-colors">[Your Agency Name]</a>
    </p>
  </div>
</footer>
