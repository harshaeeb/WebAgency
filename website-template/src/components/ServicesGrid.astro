---
// src/components/ServicesGrid.astro
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

interface Props {
  compact?: boolean;     // when true, used as a homepage teaser rather than the full services page
  hideHeading?: boolean; // when true, skip the section heading (use when the parent page already has one)
}
const { compact = false, hideHeading = false } = Astro.props;
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
  {!hideHeading && (
    <div class="text-center mb-10">
      <p class="text-sm font-medium text-[var(--brand-700)] uppercase tracking-wide mb-2">What We Do</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Our Services</h2>
      <p class="mt-2 text-slate-600">Serving {site.serviceAreas.join(", ")}</p>
    </div>
  )}

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {site.services.map((service) => {
      const serviceImage = resolveImage(service.image);
      return (
      <a
        href={`/services/${service.slug}`}
        class="group block rounded-xl overflow-hidden border border-slate-200 bg-white hover:border-[var(--brand-300)] hover:shadow-lg hover:shadow-[var(--brand-100)] transition-all"
      >
        {serviceImage ? (
          <div class="aspect-[16/10] overflow-hidden bg-[var(--brand-50)]">
            <img
              src={serviceImage}
              alt={service.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              width="640"
              height="400"
            />
          </div>
        ) : (
          <div class="aspect-[16/10] bg-[var(--brand-50)] flex items-center justify-center text-[var(--brand-300)] text-xs">
            [ {service.name} image ]
          </div>
        )}
        <div class="p-6">
          <h3 class="text-lg font-semibold text-slate-900">{service.name}</h3>
          <p class="mt-2 text-sm text-slate-600">{service.shortDescription}</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--brand-700)] group-hover:gap-2 transition-all">
            Learn more <span aria-hidden="true">&rarr;</span>
          </span>
        </div>
      </a>
      );
    })}
  </div>

  {!compact && (
    <div class="mt-10 text-center">
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-lg bg-[var(--brand)] text-white px-6 py-3 text-base font-semibold shadow-md shadow-[var(--brand-200)] hover:bg-[var(--brand-dark)] transition-colors"
      >
        Get a Free Quote
      </a>
    </div>
  )}
</section>
