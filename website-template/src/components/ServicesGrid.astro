---
// src/components/ServicesGrid.astro
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

interface Props {
  compact?: boolean;
  hideHeading?: boolean;
}
const { compact = false, hideHeading = false } = Astro.props;
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
  {!hideHeading && (
    <div class="text-center mb-12" data-reveal>
      <span class="inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-[var(--brand-50)] border border-[var(--brand-100)] rounded-full px-3 py-1">
        What We Do
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Our Services</h2>
      <p class="mt-2 text-slate-500 max-w-xl mx-auto">
        Professional service for homeowners and businesses across {site.serviceAreas.join(", ")}
      </p>
    </div>
  )}

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
    {site.services.map((service) => {
      const serviceImage = resolveImage(service.image);
      return (
        <a
          href={`/services/${service.slug}`}
          class="group flex flex-col rounded-[var(--radius,0.75rem)] overflow-hidden border border-slate-200 bg-white hover:border-[var(--brand-300)] hover:shadow-xl hover:shadow-[var(--brand-100)]/50 transition-all duration-200"
        >
          {serviceImage ? (
            <div class="aspect-[16/10] overflow-hidden bg-[var(--brand-50)]">
              <img
                src={serviceImage}
                alt={service.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="640"
                height="400"
              />
            </div>
          ) : (
            <div class="aspect-[16/10] bg-gradient-to-br from-[var(--brand-50)] to-[var(--brand-100)] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-[var(--brand-300)]">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
              </svg>
            </div>
          )}

          <div class="flex flex-col flex-1 p-6">
            <h3 class="text-base font-bold text-slate-900 group-hover:text-[var(--brand-700)] transition-colors">
              {service.name}
            </h3>
            <p class="mt-2 text-sm text-slate-500 flex-1 leading-relaxed">{service.shortDescription}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--brand-600)] group-hover:gap-2.5 transition-all">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
              </svg>
            </span>
          </div>
        </a>
      );
    })}
  </div>

  {!compact && (
    <div class="mt-12 text-center" data-reveal>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-[var(--radius,0.75rem)] bg-[var(--brand)] text-white px-7 py-3.5 text-base font-semibold shadow-lg shadow-[var(--brand-200)] hover:bg-[var(--brand-dark)] transition-colors"
      >
        Get a Free Quote
      </a>
    </div>
  )}
</section>
