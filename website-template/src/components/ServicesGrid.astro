---
// src/components/ServicesGrid.astro
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

interface Props {
  compact?: boolean;
  hideHeading?: boolean;
}
const { compact = false, hideHeading = false } = Astro.props;

// Pet service icon paths — cycles through 3 variants
const petIcons = [
  // Scissors (grooming)
  `<path stroke-linecap="round" stroke-linejoin="round" d="M7.848 8.25l1.536.887M7.848 8.25a3 3 0 1 1-5.196-3 3 3 0 0 1 5.196 3Zm1.536.887a2.165 2.165 0 0 1 1.083 1.839c.005.351.054.695.14 1.024M9.384 9.137l2.077 1.199M7.848 15.75l1.536-.887m-1.536.887a3 3 0 1 1-5.196 3 3 3 0 0 1 5.196-3Zm1.536-.887a2.165 2.165 0 0 1 1.083-1.838c.355-.06.704-.152 1.046-.27m-2.129 2.108 2.077-1.199m0-3.328a4.323 4.323 0 0 1 2.068-1.379l5.325-1.628a4.5 4.5 0 0 1 1.68-.314h.003" />`,
  // Home/boarding
  `<path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  // Paw/heart (care)
  `<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />`,
];
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
  {!hideHeading && (
    <div class="text-center mb-12" data-reveal>
      <span class="inline-block text-xs font-bold uppercase tracking-widest mb-3 rounded-full px-3 py-1 border" style="color: var(--brand-600); background: var(--brand-50); border-color: var(--brand-100);">
        Our Services
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Everything Your Pet Needs</h2>
      <p class="mt-2 text-slate-500 max-w-xl mx-auto">
        Professional pet care for families across {site.serviceAreas.slice(0, 4).join(", ")} and beyond
      </p>
    </div>
  )}

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
    {site.services.map((service, i) => {
      const serviceImage = resolveImage(service.image);
      return (
        <a
          href={`/services/${service.slug}`}
          class="group flex flex-col rounded-[var(--radius,1.25rem)] overflow-hidden border border-slate-200 bg-white card-lift hover:border-[var(--brand-300)] transition-all duration-200"
        >
          {serviceImage ? (
            <div class="aspect-[16/10] overflow-hidden" style="background: var(--brand-50);">
              <img
                src={serviceImage}
                alt={`${service.name} at ${site.business}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="640"
                height="400"
              />
            </div>
          ) : (
            <div class="relative aspect-[16/10] flex items-center justify-center" style={`background: linear-gradient(135deg, var(--brand-${600 + (i % 2) * 100}), var(--brand-${800 + (i % 2) * 100}));`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" class="w-10 h-10 opacity-70" set:html={petIcons[i % petIcons.length]} />
              <!-- Service number badge -->
              <span class="absolute top-3 right-3 w-7 h-7 rounded-full bg-white/15 border border-white/20 flex items-center justify-center text-xs font-bold text-white">
                {String(i + 1).padStart(2, "0")}
              </span>
            </div>
          )}

          <div class="flex flex-col flex-1 p-6">
            <h3 class="text-base font-bold text-slate-900 transition-colors" style="" onmouseover="" >
              {service.name}
            </h3>
            <p class="mt-2 text-sm text-slate-500 flex-1 leading-relaxed">{service.shortDescription}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold transition-all" style="color: var(--brand-600);">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
                <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
              </svg>
            </span>
          </div>
        </a>
      );
    })}
  </div>

  {!compact && (
    <div class="mt-12 text-center" data-reveal>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-semibold text-white shadow-lg transition-colors rounded-[var(--radius,1.25rem)]"
        style="background: var(--brand); box-shadow: 0 4px 20px var(--brand-200);"
      >
        Book an Appointment
      </a>
    </div>
  )}
</section>
