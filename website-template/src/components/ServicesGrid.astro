---
// src/components/ServicesGrid.astro
import { site } from "../config/site";

interface Props {
  compact?: boolean; // when true, used as a homepage teaser rather than the full services page
}
const { compact = false } = Astro.props;

// Trade-service icon set — covers common blue-collar niches.
// Each icon is a keyed SVG path. Services are matched by slug; falls back
// to a generic wrench. Add slugs here as the template is used for new niches.
const iconPaths: Record<string, string> = {
  "emergency-plumbing":  "M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 0 1-1.161.886l-.143.048a1.107 1.107 0 0 0-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 0 1-1.652.928l-.679-.906a1.125 1.125 0 0 0-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 0 0-8.862 12.872M12.75 3.031A9 9 0 0 1 21 12c0 1.067-.173 2.093-.494 3.053",
  "water-heaters":       "M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z",
  "drain-cleaning":      "M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z",
  "hvac":                "M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z",
  "electrical":          "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z",
  "roofing":             "M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25",
  "default":             "M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z",
};

function getIconPath(slug: string): string {
  return iconPaths[slug] ?? iconPaths["default"];
}
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
  <div class="text-center mb-12" data-reveal>
    <p class="text-sm font-semibold uppercase tracking-widest mb-2" style="color:var(--brand)">What We Do</p>
    <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Our Services</h2>
    <p class="mt-2 text-slate-600 max-w-xl mx-auto">Serving {site.serviceAreas.join(", ")}</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
    {site.services.map((service) => (
      <a
        href={`/services/${service.slug}`}
        class="service-card group block rounded-xl border border-slate-200 bg-white p-6 hover:border-[var(--brand)]"
      >
        <!-- Icon -->
        <div
          class="mb-4 w-11 h-11 rounded-lg flex items-center justify-center transition-colors group-hover:bg-[var(--brand)]"
          style="background:color-mix(in srgb, var(--brand) 12%, transparent)"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-5 h-5 transition-colors group-hover:text-white"
            style="color:var(--brand)"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(service.slug)} />
          </svg>
        </div>

        <h3 class="text-lg font-semibold text-slate-900">{service.name}</h3>
        <p class="mt-2 text-sm text-slate-600 leading-relaxed">{service.shortDescription}</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium transition-colors" style="color:var(--brand)">
          Learn more
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5">
            <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd"/>
          </svg>
        </span>
      </a>
    ))}
  </div>

  {!compact && (
    <div class="mt-12 text-center" data-reveal>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-lg text-white px-8 py-3.5 text-base font-semibold shadow-sm hover:opacity-90 transition-opacity"
        style="background:var(--brand)"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  )}
</section>
