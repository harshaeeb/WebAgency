---
// src/components/ServicesGrid.astro
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

interface Props {
  compact?: boolean;
  hideHeading?: boolean;
}
const { compact = false, hideHeading = false } = Astro.props;

// Trade service icons — cycles through for services without images
const iconPaths = [
  "M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z",
  "M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z",
  "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z",
];
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
  {!hideHeading && (
    <div class="text-center mb-14" data-reveal>
      <span class="inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-[var(--brand-50)] border border-[var(--brand-200)] rounded-full px-4 py-1.5">
        What We Do
      </span>
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-2">Our Services</h2>
      <p class="mt-3 text-slate-500 max-w-xl mx-auto">
        Professional service for homeowners and businesses across {site.serviceAreas.join(", ")}
      </p>
    </div>
  )}

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
    {site.services.map((service, i) => {
      const serviceImage = resolveImage(service.image);
      return (
        <a
          href={`/services/${service.slug}`}
          class="group card-lift flex flex-col rounded-[var(--radius,0.75rem)] overflow-hidden border border-slate-200 bg-white hover:border-[var(--brand-300)] transition-all duration-200"
        >
          {/* Image or icon header */}
          {serviceImage ? (
            <div class="aspect-[16/9] overflow-hidden bg-[var(--brand-50)]">
              <img
                src={serviceImage}
                alt={service.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="640"
                height="360"
              />
            </div>
          ) : (
            <div class="aspect-[16/9] bg-gradient-to-br from-[var(--brand-600)] to-[var(--brand-800)] flex items-center justify-center relative overflow-hidden">
              {/* Decorative circles */}
              <div class="absolute -bottom-6 -right-6 w-32 h-32 rounded-full bg-white/5"></div>
              <div class="absolute -top-6 -left-6 w-20 h-20 rounded-full bg-white/5"></div>
              {/* Number badge */}
              <span class="absolute top-3 right-3 w-7 h-7 rounded-full bg-white/15 text-white text-xs font-bold flex items-center justify-center">
                {String(i + 1).padStart(2, "0")}
              </span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.25"
                class="w-12 h-12 text-white/70"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[i % iconPaths.length]} />
              </svg>
            </div>
          )}

          {/* Card body */}
          <div class="flex flex-col flex-1 p-6">
            <h3 class="text-base font-bold text-slate-900 group-hover:text-[var(--brand-700)] transition-colors">
              {service.name}
            </h3>
            <p class="mt-2 text-sm text-slate-500 flex-1 leading-relaxed">{service.shortDescription}</p>
            <div class="mt-5 flex items-center justify-between">
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--brand-600)] group-hover:gap-2.5 transition-all">
                Learn more
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
                </svg>
              </span>
              <span class="text-[10px] font-bold uppercase tracking-wider text-slate-300">0{i + 1}</span>
            </div>
          </div>
        </a>
      );
    })}
  </div>

  {!compact && (
    <div class="mt-14 text-center" data-reveal>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2.5 rounded-[var(--radius,0.75rem)] bg-[var(--brand)] text-white px-8 py-4 text-base font-bold shadow-lg shadow-[var(--brand-200)] hover:bg-[var(--brand-dark)] transition-all hover:shadow-xl hover:shadow-[var(--brand-200)]/60"
      >
        Get a Free Quote
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  )}
</section>
