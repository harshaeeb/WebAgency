---
// src/components/Header.astro
// theme.headerStyle: "white" (default) = white bg + brand accent
//                    "brand"           = brand-700 bg + white text throughout
import { site } from "../config/site";

const isBrand = site.theme?.headerStyle === "brand";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header
  class={`sticky top-0 z-50 shadow-sm ${
    isBrand
      ? "bg-[var(--brand-700)] border-b border-[var(--brand-800)]"
      : "bg-white border-b border-slate-200"
  }`}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3.5 flex items-center justify-between gap-4">
    <a
      href="/"
      class={`text-lg sm:text-xl font-bold whitespace-nowrap tracking-tight ${
        isBrand ? "text-white" : "text-slate-900"
      }`}
    >
      {site.business}
    </a>

    <nav
      class={`hidden md:flex items-center gap-7 text-sm font-medium ${
        isBrand ? "text-white/80" : "text-slate-600"
      }`}
    >
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`transition-colors ${
            isBrand ? "hover:text-white" : "hover:text-[var(--brand-700)]"
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href={`tel:${site.phone}`}
      class={`inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold shadow-sm transition-colors whitespace-nowrap ${
        isBrand
          ? "bg-white text-[var(--brand-700)] hover:bg-[var(--brand-50)]"
          : "bg-[var(--brand)] text-white hover:bg-[var(--brand-dark)]"
      }`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
        <path d="M2.25 6.75c0-1.36 1.04-2.598 2.43-2.534.86.04 1.7.18 2.5.42a1.5 1.5 0 0 1 1.04 1.25l.4 2.46a1.5 1.5 0 0 1-.42 1.36l-1.2 1.2a14.93 14.93 0 0 0 6.34 6.34l1.2-1.2a1.5 1.5 0 0 1 1.36-.42l2.46.4a1.5 1.5 0 0 1 1.25 1.04c.24.8.38 1.64.42 2.5.064 1.39-1.174 2.43-2.534 2.43H18A15.75 15.75 0 0 1 2.25 8.25V6.75Z" />
      </svg>
      <span class="hidden sm:inline">{site.phoneDisplay}</span>
      <span class="sm:hidden">Call</span>
    </a>
  </div>
</header>
