---
// src/components/Header.astro
import { site } from "../config/site";

const isBrand = site.theme?.headerStyle === "brand";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header
  class={`sticky top-0 z-50 shadow-sm transition-shadow ${
    isBrand
      ? "bg-[var(--brand-700)] border-b border-[var(--brand-800)]"
      : "bg-white/95 backdrop-blur-md border-b border-slate-200/80"
  }`}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3.5 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a
      href="/"
      class={`flex items-center gap-2.5 font-bold text-lg tracking-tight whitespace-nowrap ${
        isBrand ? "text-white" : "text-slate-900"
      }`}
    >
      <span
        class={`w-8 h-8 rounded-lg flex items-center justify-center text-sm font-black flex-shrink-0 ${
          isBrand ? "bg-white/20 text-white" : "bg-[var(--brand)] text-white"
        }`}
      >
        {site.business.charAt(0)}
      </span>
      {site.business}
    </a>

    <!-- Desktop Nav -->
    <nav class={`hidden md:flex items-center gap-7 text-sm font-medium ${
      isBrand ? "text-white/80" : "text-slate-600"
    }`}>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`relative py-1 transition-colors group ${
            isBrand ? "hover:text-white" : "hover:text-[var(--brand-700)]"
          }`}
        >
          {link.label}
          <span class={`absolute bottom-0 left-0 w-0 h-0.5 rounded-full transition-all duration-200 group-hover:w-full ${
            isBrand ? "bg-white/60" : "bg-[var(--brand)]"
          }`}></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <!-- Phone CTA -->
      <a
        href={`tel:${site.phone}`}
        class={`inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold shadow-sm transition-all whitespace-nowrap hover:scale-[1.03] ${
          isBrand
            ? "bg-white text-[var(--brand-700)] hover:bg-[var(--brand-50)]"
            : "bg-[var(--brand)] text-white hover:bg-[var(--brand-dark)] shadow-[var(--brand-200)]"
        }`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0">
          <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd" />
        </svg>
        <span class="hidden sm:inline">{site.phoneDisplay}</span>
        <span class="sm:hidden">Call</span>
      </a>

      <!-- Hamburger -->
      <button
        id="nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        class={`md:hidden p-2 rounded-lg transition-colors ${
          isBrand ? "text-white hover:bg-white/10" : "text-slate-600 hover:bg-slate-100"
        }`}
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5 hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav Drawer -->
  <div
    id="mobile-nav"
    class={`md:hidden border-t ${
      isBrand
        ? "border-[var(--brand-800)] bg-[var(--brand-800)]"
        : "border-slate-100 bg-white"
    }`}
  >
    <nav class="max-w-6xl mx-auto px-4 pb-3 pt-1 flex flex-col gap-0.5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-2.5 text-sm font-medium rounded-lg transition-colors ${
            isBrand
              ? "text-white/80 hover:text-white hover:bg-white/10"
              : "text-slate-700 hover:text-[var(--brand-700)] hover:bg-[var(--brand-50)]"
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href={`tel:${site.phone}`}
        class="mt-2 mx-3 px-4 py-2.5 text-sm font-semibold text-center rounded-lg bg-[var(--brand)] text-white"
      >
        Call {site.phoneDisplay}
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      iconOpen?.classList.toggle('hidden', isOpen);
      iconClose?.classList.toggle('hidden', !isOpen);
    });
  }
</script>
