---
// src/components/Header.astro
import { site } from "../config/site";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="text-lg sm:text-xl font-bold text-slate-900 whitespace-nowrap">
      {site.business}
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
      {navLinks.map((link) => (
        <a href={link.href} class="hover:text-[var(--brand)] transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Click-to-call: always visible, the highest-converting action for trade businesses -->
    <a
      href={`tel:${site.phone}`}
      class="inline-flex items-center gap-2 rounded-full bg-[var(--brand)] text-white px-4 py-2 text-sm font-semibold shadow-sm hover:opacity-90 transition-opacity whitespace-nowrap"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
        <path d="M2.25 6.75c0-1.36 1.04-2.598 2.43-2.534.86.04 1.7.18 2.5.42a1.5 1.5 0 0 1 1.04 1.25l.4 2.46a1.5 1.5 0 0 1-.42 1.36l-1.2 1.2a14.93 14.93 0 0 0 6.34 6.34l1.2-1.2a1.5 1.5 0 0 1 1.36-.42l2.46.4a1.5 1.5 0 0 1 1.25 1.04c.24.8.38 1.64.42 2.5.064 1.39-1.174 2.43-2.534 2.43H18A15.75 15.75 0 0 1 2.25 8.25V6.75Z" />
      </svg>
      <span class="hidden sm:inline">{site.phoneDisplay}</span>
      <span class="sm:hidden">Call</span>
    </a>
  </div>
</header>
