---
// src/components/TrustBar.astro
// Horizontal trust strip between Hero and Services.
// Icons, labels, and values all pull from site.ts — no hardcoding.
import { site } from "../config/site";
---

<div class="border-b border-slate-200 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6" data-reveal-stagger>
    <!-- Years in business -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-12 text-center">
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style="background:color-mix(in srgb, var(--brand) 12%, transparent)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" style="color:var(--brand)">
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="text-left">
          <p class="text-lg font-bold text-slate-900">
            <span data-countup>{site.yearsInBusiness}</span>+ Years
          </p>
          <p class="text-xs text-slate-500 leading-tight">In Business</p>
        </div>
      </div>

      <div class="hidden sm:block w-px h-10 bg-slate-200"></div>

      <!-- Review count -->
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style="background:color-mix(in srgb, var(--brand) 12%, transparent)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" style="color:var(--brand)">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 0 0 .95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 0 0-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 0 0-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 0 0-.363-1.118l-3.976-2.888c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 0 0 .951-.69l1.519-4.674Z"/>
          </svg>
        </div>
        <div class="text-left">
          <p class="text-lg font-bold text-slate-900">
            <span data-countup>{site.googleReviewCount}</span>+ Reviews
          </p>
          <p class="text-xs text-slate-500 leading-tight">{site.googleRating}-Star Rated</p>
        </div>
      </div>

      <div class="hidden sm:block w-px h-10 bg-slate-200"></div>

      <!-- Licensed & Insured -->
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style="background:color-mix(in srgb, var(--brand) 12%, transparent)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" style="color:var(--brand)">
            <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="text-left">
          <p class="text-lg font-bold text-slate-900">Licensed</p>
          <p class="text-xs text-slate-500 leading-tight">& Fully Insured</p>
        </div>
      </div>

      <div class="hidden sm:block w-px h-10 bg-slate-200"></div>

      <!-- Service areas -->
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style="background:color-mix(in srgb, var(--brand) 12%, transparent)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" style="color:var(--brand)">
            <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="text-left">
          <p class="text-lg font-bold text-slate-900">{site.serviceAreas.length} Areas</p>
          <p class="text-xs text-slate-500 leading-tight">Served Locally</p>
        </div>
      </div>
    </div>
  </div>
</div>
