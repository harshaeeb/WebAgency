---
// src/components/ReviewsWidget.astro
//
// Two modes controlled by site.features.reviewsWidget:
// - false (default): styled section with animated star + review count, linking
//   to the business's Google review page. Zero cost, zero maintenance.
// - true (upsell): a live embedded widget showing recent reviews inline.
//   Wire your chosen reviews-widget provider's embed snippet into the block
//   below — left as a placeholder since the specific provider is a business
//   decision made per Section 3.2 of the Website Development & Hosting Strategy doc.
import { site } from "../config/site";
---

<section class="relative overflow-hidden bg-slate-900">
  <!-- Background glow -->
  <div
    class="pointer-events-none absolute inset-0 opacity-10"
    style="background: radial-gradient(ellipse at 50% 120%, var(--brand), transparent 70%);"
  ></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-20 text-center" data-reveal>
    <!-- Animated stars -->
    <div class="flex items-center justify-center gap-1.5 mb-6">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="#f59e0b"
          class="w-7 h-7 drop-shadow"
          style={`animation: starPop 0.4s ease ${0.1 * i}s both`}
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 0 0 .95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 0 0-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 0 0-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 0 0-.363-1.118l-3.976-2.888c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 0 0 .951-.69l1.519-4.674Z" />
        </svg>
      ))}
    </div>

    <p class="text-5xl font-extrabold text-white tracking-tight">
      {site.googleRating} <span class="text-2xl font-medium text-slate-400">/ 5</span>
    </p>
    <p class="mt-3 text-slate-300 text-lg">
      Based on{" "}
      <span data-countup class="font-bold text-white">{site.googleReviewCount}</span>+
      Google reviews
    </p>

    {site.features.reviewsWidget ? (
      <div class="mt-10 rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm p-8 text-sm text-slate-400">
        [ Embedded live reviews widget renders here — provider snippet not yet wired in ]
      </div>
    ) : (
      <a
        href={site.googleReviewLink}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 bg-white/10 text-white px-7 py-3.5 text-base font-semibold hover:bg-white/20 transition-colors backdrop-blur-sm"
      >
        <!-- Google G icon -->
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Read Our Reviews on Google
      </a>
    )}
  </div>
</section>

<style>
  @keyframes starPop {
    from { opacity: 0; transform: scale(0.4) rotate(-20deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }
</style>
