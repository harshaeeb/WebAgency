---
// src/components/ReviewsWidget.astro
import { site } from "../config/site";

const testimonials = site.testimonials ?? [];
---

<section class="relative overflow-hidden bg-slate-900">
  <!-- Radial brand glow -->
  <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse at center, var(--brand-800)/30%, transparent 70%);" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <!-- Header -->
    <div class="text-center mb-10" data-reveal>
      <div class="flex items-center justify-center gap-1 mb-3">
        {Array.from({ length: 5 }).map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 text-amber-400">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 0 0 .95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 0 0-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 0 0-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 0 0-.363-1.118l-3.976-2.888c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 0 0 .951-.69l1.519-4.674Z" />
          </svg>
        ))}
      </div>
      <p class="text-4xl font-black text-white">{site.googleRating} out of 5</p>
      <p class="mt-2 text-slate-400">
        Based on <strong class="text-white">{site.googleReviewCount}+</strong> Google reviews
      </p>
    </div>

    <!-- Testimonial cards -->
    {testimonials.length > 0 && (
      <div class="grid sm:grid-cols-3 gap-5 mb-10" data-reveal-stagger>
        {testimonials.map((t) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 flex flex-col gap-4">
            <!-- Quote icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 opacity-30 text-white flex-shrink-0">
              <path fill-rule="evenodd" d="M4.804 21.644A6.707 6.707 0 0 0 6 21.75a6.75 6.75 0 0 0 6.75-6.75v-.75H7.5a3 3 0 0 1-3-3V9.75a3 3 0 0 1 3-3h.75V6a6.75 6.75 0 0 1 6.75-6.75h.75v4.5H15a2.25 2.25 0 0 0-2.25 2.25v.75h4.5v.75a6.75 6.75 0 0 1-6.75 6.75H9.75v.75A3.75 3.75 0 0 1 6 18.75c-.584 0-1.14-.133-1.638-.372L4.804 21.644Z" clip-rule="evenodd" />
            </svg>
            <p class="text-sm text-slate-300 leading-relaxed flex-1">{t.text}</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white flex-shrink-0" style="background: var(--brand-600);">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-semibold text-white">{t.name}</p>
                {t.role && <p class="text-xs text-slate-500">{t.role}</p>}
              </div>
              <div class="ml-auto flex gap-0.5">
                {Array.from({ length: t.rating ?? 5 }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="currentColor" class="w-3 h-3 text-amber-400">
                    <path d="M6 .25a.75.75 0 0 1 .673.418l1.09 2.21 2.44.353a.75.75 0 0 1 .416 1.28l-1.764 1.719.416 2.428a.75.75 0 0 1-1.088.79L6 8.347 3.817 9.45a.75.75 0 0 1-1.088-.79l.416-2.428L1.381 4.51a.75.75 0 0 1 .416-1.28l2.44-.353L5.327.668A.75.75 0 0 1 6 .25Z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- CTA -->
    <div class="text-center" data-reveal>
      {site.features.reviewsWidget ? (
        <div class="rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm p-8 text-sm text-white/50">
          [ Embedded live reviews widget renders here ]
        </div>
      ) : (
        <a
          href={site.googleReviewLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 rounded-2xl bg-white px-6 py-3 text-base font-semibold shadow-lg transition-colors hover:bg-slate-50" style="color: var(--brand-700);"
        >
          <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Read Our Reviews on Google
        </a>
      )}
    </div>
  </div>
</section>
