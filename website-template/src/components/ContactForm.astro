---
// src/components/ContactForm.astro
import { site } from "../config/site";
---

<form
  id="inquiry-form"
  action="/api/inquiry"
  method="POST"
  enctype="multipart/form-data"
  class="space-y-5"
>
  <div>
    <label for="name" class="block text-sm font-semibold text-slate-700 mb-1.5">Full Name <span class="text-[var(--brand-500)]">*</span></label>
    <input
      type="text" id="name" name="name" required
      placeholder="Jane Smith"
      class="w-full rounded-[var(--radius,0.75rem)] border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent focus:bg-white transition-colors"
    />
  </div>

  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label for="phone" class="block text-sm font-semibold text-slate-700 mb-1.5">Phone</label>
      <input
        type="tel" id="phone" name="phone"
        placeholder="(972) 555-0100"
        class="w-full rounded-[var(--radius,0.75rem)] border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent focus:bg-white transition-colors"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5">Email</label>
      <input
        type="email" id="email" name="email"
        placeholder="you@example.com"
        class="w-full rounded-[var(--radius,0.75rem)] border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent focus:bg-white transition-colors"
      />
    </div>
  </div>
  <p class="text-xs text-slate-400 -mt-2">Please provide at least a phone number or email so we can reach you.</p>

  <div>
    <label for="message" class="block text-sm font-semibold text-slate-700 mb-1.5">How can we help? <span class="text-[var(--brand-500)]">*</span></label>
    <textarea
      id="message" name="message" rows="4" required
      placeholder="Describe what you need — the more detail the better..."
      class="w-full rounded-[var(--radius,0.75rem)] border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent focus:bg-white transition-colors resize-none"
    ></textarea>
  </div>

  <div>
    <label for="photo" class="block text-sm font-semibold text-slate-700 mb-1.5">
      Photo <span class="text-slate-400 font-normal">(optional — helpful for quotes)</span>
    </label>
    <div class="w-full rounded-[var(--radius,0.75rem)] border border-dashed border-slate-300 bg-slate-50 px-4 py-3">
      <input
        type="file" id="photo" name="photo" accept="image/*"
        class="w-full text-sm text-slate-500 file:mr-3 file:rounded-lg file:border-0 file:bg-[var(--brand-100)] file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-[var(--brand-700)] hover:file:bg-[var(--brand-200)] cursor-pointer"
      />
      <p class="text-xs text-slate-400 mt-1.5">Max 5 MB · JPG, PNG, HEIC</p>
    </div>
  </div>

  <div class="pt-2">
    <button
      type="submit"
      class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 rounded-[var(--radius,0.75rem)] bg-[var(--brand)] text-white px-8 py-3.5 text-base font-bold shadow-lg shadow-[var(--brand-200)] hover:bg-[var(--brand-dark)] transition-all hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
        <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.897 28.897 0 0 0 15.293-7.154.75.75 0 0 0 0-1.115A28.897 28.897 0 0 0 3.105 2.288Z" />
      </svg>
      Send Request
    </button>
  </div>

  <p id="inquiry-status" class="text-sm" role="status" aria-live="polite"></p>

  <p class="text-xs text-slate-400 border-t border-slate-100 pt-4">
    Prefer to talk? Call us directly at
    <a href={`tel:${site.phone}`} class="text-[var(--brand)] font-semibold hover:underline">{site.phoneDisplay}</a>.
  </p>
</form>

<script>
  const form = document.getElementById("inquiry-form") as HTMLFormElement | null;
  const status = document.getElementById("inquiry-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) submitBtn.disabled = true;
    status.textContent = "Sending your request…";
    status.className = "text-sm text-slate-500";

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
      });
      const data = (await res.json()) as { ok: boolean; error?: string };

      if (data.ok) {
        status.textContent = "✓ Request received! We’ll be in touch shortly.";
        status.className = "text-sm text-green-600 font-semibold";
        form.reset();
      } else {
        status.textContent = data.error || "Something went wrong. Please call us directly.";
        status.className = "text-sm text-red-600 font-medium";
      }
    } catch {
      status.textContent = "Something went wrong. Please call us directly.";
      status.className = "text-sm text-red-600 font-medium";
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
