---
// src/components/Hero.astro
import { site } from "../config/site";
---

<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
  <!-- Subtle grid pattern overlay -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(var(--brand) 1px, transparent 1px), linear-gradient(90deg, var(--brand) 1px, transparent 1px); background-size: 48px 48px;"
  ></div>
  <!-- Brand glow blob -->
  <div
    class="pointer-events-none absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full opacity-20 blur-3xl"
    style="background: var(--brand);"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 grid md:grid-cols-2 gap-12 items-center">
    <!-- Left: text content with slide-up animation -->
    <div class="hero-animate">
      <p class="inline-flex items-center gap-2 text-sm font-medium rounded-full px-3 py-1 mb-4 border border-white/20 text-white/80 bg-white/10 backdrop-blur-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" style="color:var(--brand)">
          <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
        </svg>
        Serving {site.serviceAreas.slice(0, 3).join(", ")} & nearby
      </p>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {site.tagline}
      </h1>

      <p class="mt-4 text-lg text-slate-300">
        {site.yearsInBusiness}+ years serving local homeowners and businesses, with{" "}
        {site.googleReviewCount}+ five-star reviews on Google.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={`tel:${site.phone}`}
          class="cta-pulse inline-flex items-center justify-center gap-2 rounded-lg text-white px-6 py-3 text-base font-semibold shadow-lg transition-opacity hover:opacity-90"
          style="background: var(--brand);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 16.352V17.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd" />
          </svg>
          Call {site.phoneDisplay}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-lg border border-white/30 text-white px-6 py-3 text-base font-semibold hover:bg-white/10 transition-colors"
        >
          Request a Quote
        </a>
      </div>
    </div>

    <!-- Right: illustration / client photo -->
    <div class="relative flex items-center justify-center">
      <!--
        Replace this SVG illustration with a real client photo before launch.
        Drop the image in public/images/ and swap the <svg> below for:
        <img src="/images/your-photo.jpg" alt="[descriptive alt text]"
             class="rounded-2xl shadow-2xl w-full object-cover aspect-[4/3]" />
      -->
      <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-slate-800 flex items-center justify-center">
        <svg viewBox="0 0 480 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full p-8">
          <!-- House outline -->
          <rect x="120" y="160" width="240" height="160" rx="4" fill="#1e293b" stroke="#334155" stroke-width="2"/>
          <!-- Roof -->
          <polygon points="100,165 240,70 380,165" fill="#0f172a" stroke="#334155" stroke-width="2"/>
          <!-- Door -->
          <rect x="208" y="240" width="64" height="80" rx="4" fill="#0f172a" stroke="#334155" stroke-width="1.5"/>
          <circle cx="264" cy="283" r="4" fill="#475569"/>
          <!-- Windows -->
          <rect x="140" y="200" width="56" height="44" rx="3" fill="#0f172a" stroke="#334155" stroke-width="1.5"/>
          <line x1="168" y1="200" x2="168" y2="244" stroke="#334155" stroke-width="1"/>
          <line x1="140" y1="222" x2="196" y2="222" stroke="#334155" stroke-width="1"/>
          <rect x="284" y="200" width="56" height="44" rx="3" fill="#0f172a" stroke="#334155" stroke-width="1.5"/>
          <line x1="312" y1="200" x2="312" y2="244" stroke="#334155" stroke-width="1"/>
          <line x1="284" y1="222" x2="340" y2="222" stroke="#334155" stroke-width="1"/>
          <!-- Wrench tool (large, centered above house) -->
          <g transform="translate(198,88) rotate(-35,42,42)">
            <path d="M56 14a18 18 0 0 0-18 18c0 4.2 1.5 8 3.9 11L8 77a6 6 0 1 0 8.5 8.5l33.8-33.8C53 54 56.8 56 60 56a18 18 0 1 0-4-42Zm0 28a10 10 0 1 1 0-20 10 10 0 0 1 0 20Z" fill="none" stroke-width="3" stroke="currentColor" style="color:var(--brand)"/>
          </g>
          <!-- Pipe + water drop -->
          <rect x="310" y="230" width="14" height="60" rx="7" fill="none" stroke="#38bdf8" stroke-width="2.5"/>
          <ellipse cx="317" cy="300" rx="7" ry="9" fill="#38bdf8" opacity="0.7"/>
          <!-- Ground line -->
          <line x1="60" y1="320" x2="420" y2="320" stroke="#334155" stroke-width="2"/>
          <!-- Brand accent dots -->
          <circle cx="100" cy="300" r="5" fill="currentColor" style="color:var(--brand)" opacity="0.6"/>
          <circle cx="380" cy="300" r="5" fill="currentColor" style="color:var(--brand)" opacity="0.6"/>
          <circle cx="240" cy="50" r="7" fill="currentColor" style="color:var(--brand)" opacity="0.8"/>
        </svg>
      </div>
      <!-- Floating badge -->
      <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-xl px-4 py-3 flex items-center gap-3 border border-slate-100">
        <div class="flex -space-x-1">
          {Array.from({ length: 5 }).map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#f59e0b" class="w-4 h-4">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
            </svg>
          ))}
        </div>
        <div class="text-xs leading-tight">
          <p class="font-bold text-slate-900">{site.googleRating} / 5</p>
          <p class="text-slate-500">{site.googleReviewCount}+ reviews</p>
        </div>
      </div>
    </div>
  </div>
</section>
