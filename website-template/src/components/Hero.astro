---
// src/components/Hero.astro
// Reads site.theme for layout ("split" | "centered") and heroPattern (true/false).
// Falls back to a brand-tinted placeholder if no hero image has been uploaded yet.
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";
import TrustBar from "./TrustBar.astro";

const heroImage = resolveImage(site.images?.hero);
const isCentered = site.theme?.heroLayout === "centered";
const showPattern = site.theme?.heroPattern !== false; // default true
const showTrustBar = site.theme?.showTrustBar !== false; // default true
const eyebrow = site.heroEyebrow ?? `Serving ${site.serviceAreas.slice(0, 3).join(", ")} & nearby`;
---

<section
  class={`relative overflow-hidden bg-gradient-to-b from-[var(--brand-50)] via-[var(--brand-50)]/60 to-white border-b border-[var(--brand-100)] ${
    showPattern ? "hero-pattern" : ""
  }`}
>
  <div
    class="pointer-events-none absolute -top-32 -right-32 w-[480px] h-[480px] rounded-full bg-[var(--brand-200)] opacity-30 blur-3xl"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-16 -left-16 w-64 h-64 rounded-full bg-[var(--brand-100)] opacity-40 blur-2xl"
    aria-hidden="true"
  ></div>
  <div class="absolute inset-0 bg-white/50" aria-hidden="true"></div>

  <div
    class={`relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 ${
      isCentered
        ? "flex flex-col items-center text-center gap-8"
        : "grid md:grid-cols-2 gap-10 items-center"
    }`}
  >
    <div data-reveal-stagger class={isCentered ? "max-w-2xl" : ""}>
      <span
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--brand-700)] bg-[var(--brand-100)] border border-[var(--brand-200)] rounded-full px-3.5 py-1 mb-5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-[var(--brand-500)]">
          <path fill-rule="evenodd" d="M8 1.75a.75.75 0 0 1 .692.462l1.41 3.393 3.664.293a.75.75 0 0 1 .428 1.317l-2.791 2.39.853 3.575a.75.75 0 0 1-1.12.814L8 11.91l-3.136 1.894a.75.75 0 0 1-1.12-.814l.853-3.575-2.79-2.39a.75.75 0 0 1 .427-1.317l3.663-.293 1.411-3.393A.75.75 0 0 1 8 1.75Z" clip-rule="evenodd" />
        </svg>
        {eyebrow}
      </span>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight">
        {site.tagline}
      </h1>

      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        {site.yearsInBusiness}+ years serving local homeowners and businesses —
        {site.googleReviewCount}+ five-star reviews on Google.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={`tel:${site.phone}`}
          class="inline-flex items-center justify-center gap-2 rounded-[var(--radius,0.75rem)] bg-[var(--brand)] text-white px-6 py-3 text-base font-semibold shadow-md shadow-[var(--brand-200)] hover:bg-[var(--brand-dark)] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" />
          </svg>
          Call {site.phoneDisplay}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-[var(--radius,0.75rem)] border-2 border-[var(--brand-300)] bg-white/80 text-[var(--brand-700)] px-6 py-3 text-base font-semibold hover:bg-[var(--brand-50)] hover:border-[var(--brand-400)] transition-colors backdrop-blur-sm"
        >
          Get a Free Quote
        </a>
      </div>

      <div class="mt-6 flex items-center gap-2 text-sm text-slate-500">
        <span class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 text-amber-400">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
            </svg>
          ))}
        </span>
        <span><strong class="text-slate-700">{site.googleRating}</strong> · {site.googleReviewCount}+ Google reviews</span>
      </div>
    </div>

    {!isCentered && (
      <div data-reveal class="relative">
        {heroImage ? (
          <div class="aspect-[4/3] rounded-[var(--radius,0.75rem)] overflow-hidden shadow-2xl shadow-[var(--brand-200)] ring-1 ring-[var(--brand-100)]">
            <img
              src={heroImage}
              alt={`${site.business} team and service vehicle`}
              class="w-full h-full object-cover"
              width="800"
              height="600"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--brand-900)]/20 to-transparent"></div>
          </div>
        ) : (
          <div class="aspect-[4/3] rounded-[var(--radius,0.75rem)] bg-gradient-to-br from-[var(--brand-100)] to-[var(--brand-50)] border border-[var(--brand-200)] flex items-center justify-center text-[var(--brand-400)] text-sm">
            [ Hero image goes here — see site.images.hero ]
          </div>
        )}

        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg shadow-slate-200 border border-slate-100 px-4 py-3 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-[var(--brand-100)] flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-[var(--brand-600)]">
              <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-900">Licensed & Insured</p>
            <p class="text-xs text-slate-500">{site.yearsInBusiness}+ years in {site.city}</p>
          </div>
        </div>
      </div>
    )}
  </div>
</section>

{showTrustBar && <TrustBar />}
