---
// src/components/Hero.astro
import { site } from "../config/site";
---

<section class="bg-slate-50 border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 grid md:grid-cols-2 gap-10 items-center">
    <div>
      <p class="inline-flex items-center gap-2 text-sm font-medium text-[var(--brand)] bg-[var(--brand)]/10 rounded-full px-3 py-1 mb-4">
        Serving {site.serviceAreas.slice(0, 3).join(", ")} & nearby
      </p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight">
        {site.tagline}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        {site.yearsInBusiness}+ years serving local homeowners and businesses, with{" "}
        {site.googleReviewCount}+ five-star reviews on Google.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={`tel:${site.phone}`}
          class="inline-flex items-center justify-center rounded-lg bg-[var(--brand)] text-white px-6 py-3 text-base font-semibold shadow-sm hover:opacity-90 transition-opacity"
        >
          Call {site.phoneDisplay}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-lg border border-slate-300 text-slate-700 px-6 py-3 text-base font-semibold hover:bg-slate-100 transition-colors"
        >
          Request a Quote
        </a>
      </div>
    </div>

    <div class="relative">
      <!--
        Replace with a real client photo (public/images/...) before launch.
        Placeholder kept intentionally plain rather than a stock photo —
        per CLAUDE.md, don't use stock photos unless explicitly provided.
      -->
      <div class="aspect-[4/3] rounded-2xl bg-slate-200 flex items-center justify-center text-slate-400 text-sm">
        [ Client photo goes here ]
      </div>
    </div>
  </div>
</section>
