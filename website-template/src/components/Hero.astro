---
// src/components/Hero.astro
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";
import TrustBar from "./TrustBar.astro";

const heroImage = resolveImage(site.images?.hero);
const isCentered = site.theme?.heroLayout === "centered";
const showPattern = site.theme?.heroPattern !== false;
const showTrustBar = site.theme?.showTrustBar !== false;
const eyebrow = site.heroEyebrow ?? `Serving ${site.serviceAreas.slice(0, 3).join(", ")} & nearby`;
---

<section
  class={`relative overflow-hidden ${showPattern ? "hero-pattern" : ""}`}
  style="background: linear-gradient(155deg, var(--brand-50) 0%, #f8fafc 55%, #fff 100%); border-bottom: 1px solid var(--brand-100);"
>
  <!-- Glow blobs -->
  <div class="pointer-events-none absolute -top-32 -right-32 w-[520px] h-[520px] rounded-full opacity-25 blur-3xl" style="background: var(--brand-300);" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-20 -left-20 w-72 h-72 rounded-full opacity-30 blur-2xl" style="background: var(--brand-100);" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-white/50" aria-hidden="true"></div>

  <div
    class={`relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 ${
      isCentered
        ? "flex flex-col items-center text-center gap-8"
        : "grid md:grid-cols-2 gap-12 items-center"
    }`}
  >
    <!-- Text block -->
    <div data-reveal-stagger class={isCentered ? "max-w-2xl" : ""}>
      <!-- Eyebrow pill -->
      <span class="inline-flex items-center gap-1.5 text-sm font-semibold rounded-full px-3.5 py-1 mb-5 border" style="color: var(--brand-700); background: var(--brand-100); border-color: var(--brand-200);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5" style="color: var(--brand-500);">
          <path d="M9.653 16.915l-.005-.003-.019-.01a20.759 20.759 0 0 1-1.162-.682 22.045 22.045 0 0 1-2.582-2.184C4.045 12.733 2 10.352 2 7.5a4.5 4.5 0 0 1 8-2.828A4.5 4.5 0 0 1 18 7.5c0 2.852-2.044 5.233-3.885 6.82a22.049 22.049 0 0 1-3.744 2.862l-.019.01-.005.003h-.002a.739.739 0 0 1-.69.001l-.002-.001Z" />
        </svg>
        {eyebrow}
      </span>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-[3.25rem] font-black text-slate-900 leading-tight tracking-tight">
        {site.tagline}
      </h1>

      <p class="mt-5 text-lg text-slate-600 leading-relaxed">
        {site.yearsInBusiness}+ years caring for North Dallas pets —
        {site.googleReviewCount}+ five-star reviews from happy pet parents.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap gap-3">
        <!-- Pulsing phone CTA -->
        <div class="relative inline-flex">
          <span class="absolute inset-0 rounded-[var(--radius,1.25rem)] cta-ping pointer-events-none" style="background: var(--brand-400);"></span>
          <a
            href={`tel:${site.phone}`}
            class="relative inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-bold text-white shadow-lg transition-colors rounded-[var(--radius,1.25rem)]"
            style="background: var(--brand); box-shadow: 0 4px 20px var(--brand-300);"
            onmouseover="this.style.background='var(--brand-dark)'" onmouseout="this.style.background='var(--brand)'"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" />
            </svg>
            Call {site.phoneDisplay}
          </a>
        </div>

        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold border-2 bg-white/80 backdrop-blur-sm transition-colors rounded-[var(--radius,1.25rem)]"
          style="color: var(--brand-700); border-color: var(--brand-300);"
          onmouseover="this.style.background='var(--brand-50)'; this.style.borderColor='var(--brand-400)';" onmouseout="this.style.background='rgba(255,255,255,0.8)'; this.style.borderColor='var(--brand-300)';"
        >
          Book a Grooming
        </a>
      </div>

      <!-- Avatar stack social proof -->
      <div class="mt-7 flex items-center gap-3">
        <div class="flex -space-x-2.5">
          {["S","C","J","M"].map((initial, i) => (
            <div
              class="w-8 h-8 rounded-full border-2 border-white flex items-center justify-center text-xs font-bold text-white"
              style={`background: var(--brand-${[400,500,600,700][i]});`}
            >
              {initial}
            </div>
          ))}
        </div>
        <div class="text-sm text-slate-500">
          <span class="flex gap-0.5 mb-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-amber-400">
                <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
              </svg>
            ))}
          </span>
          <strong class="text-slate-700">{site.googleRating}</strong> · {site.googleReviewCount}+ happy pet parents
        </div>
      </div>
    </div>

    <!-- Image / placeholder block -->
    {!isCentered && (
      <div data-reveal class="relative">
        {heroImage ? (
          <div class="aspect-[4/3] overflow-hidden shadow-2xl ring-1" style="border-radius: var(--radius,1.25rem); box-shadow: 0 24px 60px var(--brand-200); ring-color: var(--brand-100);">
            <img
              src={heroImage}
              alt={`${site.business} — professional pet grooming in ${site.city}, TX`}
              class="w-full h-full object-cover"
              width="800"
              height="600"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/20 to-transparent"></div>
          </div>
        ) : (
          <div class="aspect-[4/3] flex flex-col items-center justify-center gap-4 border" style="border-radius: var(--radius,1.25rem); background: linear-gradient(135deg, var(--brand-50), var(--brand-100)); border-color: var(--brand-200);">
            <!-- Paw print placeholder -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="w-16 h-16" style="color: var(--brand-300);" fill="currentColor">
              <ellipse cx="16" cy="20" rx="5" ry="7" />
              <ellipse cx="30" cy="14" rx="5" ry="7" />
              <ellipse cx="44" cy="18" rx="5" ry="7" />
              <ellipse cx="54" cy="32" rx="5" ry="7" transform="rotate(20 54 32)"/>
              <path d="M32 28c-10 0-18 6-16 16 1 5 6 10 16 10s15-5 16-10c2-10-6-16-16-16Z"/>
            </svg>
            <p class="text-sm font-medium" style="color: var(--brand-400);">
              [ Client photo goes here ]
            </p>
          </div>
        )}

        <!-- Floating badge: Certified Groomers -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl border border-slate-100 px-4 py-3 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--brand-100);">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" style="color: var(--brand-600);">
              <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-900">Certified Groomers</p>
            <p class="text-xs text-slate-500">{site.yearsInBusiness}+ years experience</p>
          </div>
        </div>

        <!-- Floating badge: Cage-Free -->
        <div class="absolute -top-4 -right-4 rounded-2xl shadow-xl border px-4 py-3 flex items-center gap-2" style="background: var(--brand-600); border-color: var(--brand-700);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-white/80 flex-shrink-0">
            <path d="M9.653 16.915l-.005-.003-.019-.01a20.759 20.759 0 0 1-1.162-.682 22.045 22.045 0 0 1-2.582-2.184C4.045 12.733 2 10.352 2 7.5a4.5 4.5 0 0 1 8-2.828A4.5 4.5 0 0 1 18 7.5c0 2.852-2.044 5.233-3.885 6.82a22.049 22.049 0 0 1-3.744 2.862l-.019.01-.005.003h-.002a.739.739 0 0 1-.69.001l-.002-.001Z" />
          </svg>
          <div>
            <p class="text-xs font-bold text-white">Cage-Free</p>
            <p class="text-xs text-white/70">& Stress-Free</p>
          </div>
        </div>
      </div>
    )}
  </div>
</section>

{showTrustBar && <TrustBar />}
