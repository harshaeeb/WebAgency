---
// src/components/Hero.astro
//
// Uses the generated brand palette (--brand-50 through --brand-900) for a
// layered gradient background and accent decoration — clean/corporate
// direction: subtle, not loud. Falls back to a plain placeholder box if
// site.images.hero hasn't been generated yet (see scripts/generate-images.ts
// and the imagePrompt fields in site.ts).
import { site } from "../config/site";

const heroImage = site.images?.hero;
---

<section class="relative overflow-hidden bg-gradient-to-b from-[var(--brand-50)] via-white to-white border-b border-slate-200">
  <!-- Decorative blurred accent shape — subtle depth, not a loud effect -->
  <div
    class="pointer-events-none absolute -top-24 -right-24 w-96 h-96 rounded-full bg-[var(--brand-200)] opacity-40 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 grid md:grid-cols-2 gap-10 items-center">
    <div>
      <p class="inline-flex items-center gap-2 text-sm font-medium text-[var(--brand-700)] bg-[var(--brand-100)] rounded-full px-3 py-1 mb-4">
        Serving {site.serviceAreas.slice(0, 3).join(", ")} & nearby
      </p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight">
        {site.tagline}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        {site.yearsInBusiness}+ years serving local homeowners and businesses, with{" "}
        {site.googleReviewCount}+ five-star reviews on Google.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={`tel:${site.phone}`}
          class="inline-flex items-center justify-center rounded-lg bg-[var(--brand)] text-white px-6 py-3 text-base font-semibold shadow-md shadow-[var(--brand-200)] hover:bg-[var(--brand-dark)] transition-colors"
        >
          Call {site.phoneDisplay}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-700 px-6 py-3 text-base font-semibold hover:bg-slate-50 transition-colors"
        >
          Request a Quote
        </a>
      </div>
    </div>

    <div class="relative">
      {heroImage ? (
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl shadow-[var(--brand-100)] ring-1 ring-slate-900/5">
          <img
            src={heroImage}
            alt={`${site.business} team and service vehicle`}
            class="w-full h-full object-cover"
            width="800"
            height="600"
          />
        </div>
      ) : (
        // Fallback placeholder — shown only if no hero image has been
        // generated/provided yet. Kept intentionally plain rather than a
        // stock photo per CLAUDE.md.
        <div class="aspect-[4/3] rounded-2xl bg-[var(--brand-50)] border border-[var(--brand-100)] flex items-center justify-center text-[var(--brand-400)] text-sm">
          [ Hero image goes here — see site.images.hero ]
        </div>
      )}
    </div>
  </div>
</section>

