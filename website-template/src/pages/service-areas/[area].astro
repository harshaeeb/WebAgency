---
// src/pages/service-areas/[area].astro
//
// Generates one dedicated page per service area when a client serves
// multiple towns with meaningfully different content.
//
// HOW TO ACTIVATE FOR A CLIENT:
// 1. Add a `serviceAreaPages` array to site.ts with an entry per town.
// 2. Replace the getStaticPaths body below with the real implementation.
// 3. Fill each entry with town-specific copy (duplicate content = SEO anti-pattern).
//
// LEFT DISABLED BY DEFAULT: a half-filled generic page is worse for SEO than none.

import Base from "../../layouts/Base.astro";
import ClickToCall from "../../components/ClickToCall.astro";
import ContactForm from "../../components/ContactForm.astro";
import { site } from "../../config/site";

export function getStaticPaths() {
  // Returns empty until serviceAreaPages is configured in site.ts.
  // Replace with:
  //   return site.serviceAreaPages.map((area) => ({
  //     params: { area: area.slug },
  //     props: { area },
  //   }));
  return [];
}

const area = { slug: "", name: "", headline: "", body: "" };
const title = `${area.name} | ${site.business}`;
const description = area.headline;
---

<Base title={title} description={description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <p class="text-sm font-medium text-[var(--brand)]">{site.business}</p>
    <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-slate-900">{area.headline}</h1>
    <div class="mt-4 text-lg text-slate-600 space-y-4">
      <p>{area.body}</p>
    </div>
    <div class="mt-8">
      <ClickToCall label={`Call about service in ${area.name}`} />
    </div>
  </section>

  <section class="bg-slate-50 border-t border-slate-200">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Request a Quote in {area.name}</h2>
      <ContactForm />
    </div>
  </section>
</Base>
