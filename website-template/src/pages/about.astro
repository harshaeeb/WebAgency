---
// src/pages/about.astro
import Base from "../layouts/Base.astro";
import ClickToCall from "../components/ClickToCall.astro";
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

const title = `About ${site.business} | Pet Grooming & Boarding in ${site.city}, ${site.state}`;
const description = `${site.business} has served pets and families across ${site.serviceAreas.join(", ")} for ${site.yearsInBusiness}+ years. Certified groomers, cage-free boarding, stress-free care.`;
const aboutImage = resolveImage(site.images?.about);
---

<Base title={title} description={description}>
  <!-- Page header -->
  <section class="relative overflow-hidden border-b" style="background: linear-gradient(to bottom, var(--brand-50), white); border-color: var(--brand-100);">
    <div class="pointer-events-none absolute -top-16 -right-16 w-64 h-64 rounded-full opacity-30 blur-3xl" style="background: var(--brand-200);" aria-hidden="true"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 py-12" data-reveal>
      <span class="inline-block text-xs font-bold uppercase tracking-widest mb-3 rounded-full px-3 py-1 border" style="color: var(--brand-600); background: var(--brand-50); border-color: var(--brand-100);">Our Story</span>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">About {site.business}</h1>
    </div>
  </section>

  <!-- Two-column content -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-14 items-start">
    <div class="space-y-5 text-slate-600 leading-relaxed" data-reveal-stagger>
      <p class="text-lg text-slate-700 font-medium">
        Only Paws TX was born from a simple belief: your pets deserve the same care and attention you'd want for yourself.
      </p>
      <p>
        Founded in {new Date().getFullYear() - site.yearsInBusiness} by a lifelong animal lover right here in Frisco, we started as a one-suite grooming studio and grew into a full-service pet spa serving thousands of dogs and cats across the North Dallas area. {site.yearsInBusiness} years later, our mission hasn't changed — make every pet feel safe, loved, and pampered.
      </p>
      <p>
        Our team of certified groomers and pet care specialists brings years of hands-on experience, ongoing training, and a genuine passion for animals to every single appointment. We work at your pet's pace — never rushed, never forced. Low-stress handling is standard practice here, not an add-on.
      </p>
      <p>
        We keep it simple: transparent pricing, no surprise fees, honest conversations about what your pet actually needs. That approach has earned us {site.googleReviewCount}+ five-star Google reviews — and more importantly, the trust of thousands of North Dallas families.
      </p>

      <!-- Trust stats -->
      <div class="pt-4 grid grid-cols-2 gap-4">
        <div class="rounded-2xl p-4 border" style="background: var(--brand-50); border-color: var(--brand-100);">
          <p class="text-3xl font-bold" style="color: var(--brand-700);">{site.yearsInBusiness}+</p>
          <p class="text-sm text-slate-500 mt-1">Years in business</p>
        </div>
        <div class="rounded-2xl bg-amber-50 border border-amber-100 p-4">
          <p class="text-3xl font-bold text-amber-600">{site.googleRating}★</p>
          <p class="text-sm text-slate-500 mt-1">{site.googleReviewCount}+ Google reviews</p>
        </div>
        <div class="rounded-2xl bg-green-50 border border-green-100 p-4">
          <p class="text-3xl font-bold text-green-600">{site.services.length}</p>
          <p class="text-sm text-slate-500 mt-1">Pet care services</p>
        </div>
        <div class="rounded-2xl p-4 border" style="background: var(--brand-50); border-color: var(--brand-100);">
          <p class="text-3xl font-bold" style="color: var(--brand-700);">{site.serviceAreas.length}</p>
          <p class="text-sm text-slate-500 mt-1">Cities served</p>
        </div>
      </div>

      <!-- What sets us apart -->
      <div class="pt-2 space-y-3">
        <h2 class="text-base font-bold text-slate-900">What sets us apart</h2>
        {[
          { icon: "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z", text: "Cage-free boarding — your dog sleeps in a cozy suite, not a kennel" },
          { icon: "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z", text: "Certified groomers trained in low-stress, fear-free handling" },
          { icon: "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z", text: "Cat grooming in a separate, quiet space — no dog noise or stress" },
          { icon: "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z", text: "Transparent pricing — no surprise fees, ever" },
          { icon: "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z", text: "Photo updates when your pet is done — because you miss them" },
        ].map(item => (
          <div class="flex items-start gap-3 text-sm text-slate-600">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--brand-500);">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
            {item.text}
          </div>
        ))}
      </div>

      <div class="pt-2">
        <ClickToCall />
      </div>
    </div>

    <!-- Image or placeholder -->
    <div data-reveal>
      {aboutImage ? (
        <div class="aspect-[4/3] overflow-hidden shadow-xl ring-1" style="border-radius: 1.25rem; box-shadow: 0 20px 40px var(--brand-100); ring-color: var(--brand-100);">
          <img
            src={aboutImage}
            alt={`${site.business} team — pet grooming professionals in ${site.city}, TX`}
            class="w-full h-full object-cover"
            width="640"
            height="480"
          />
        </div>
      ) : (
        <div class="space-y-4">
          <div class="aspect-[4/3] rounded-2xl flex flex-col items-center justify-center gap-4 border" style="background: linear-gradient(135deg, var(--brand-50), var(--brand-100)); border-color: var(--brand-200);">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="w-16 h-16" style="color: var(--brand-300);" fill="currentColor">
              <ellipse cx="16" cy="20" rx="5" ry="7" />
              <ellipse cx="30" cy="14" rx="5" ry="7" />
              <ellipse cx="44" cy="18" rx="5" ry="7" />
              <ellipse cx="54" cy="32" rx="5" ry="7" transform="rotate(20 54 32)"/>
              <path d="M32 28c-10 0-18 6-16 16 1 5 6 10 16 10s15-5 16-10c2-10-6-16-16-16Z"/>
            </svg>
            <p class="text-sm font-medium" style="color: var(--brand-400);">[ About photo goes here ]</p>
          </div>

          <!-- Service area pills -->
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">Proudly Serving</p>
            <div class="flex flex-wrap gap-2">
              {site.serviceAreas.map(area => (
                <span class="text-xs px-3 py-1 rounded-full border font-medium" style="background: var(--brand-50); border-color: var(--brand-200); color: var(--brand-700);">
                  {area}
                </span>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
</Base>
