---
// src/pages/contact.astro
import Base from "../layouts/Base.astro";
import ContactForm from "../components/ContactForm.astro";
import { site } from "../config/site";

const title = `Contact ${site.business} | ${site.city}, ${site.state}`;
const description = `Get in touch with ${site.business} for a free quote. Call ${site.phoneDisplay} or send us your details and we'll get back to you.`;
const mapsQuery = encodeURIComponent(site.address);
---

<Base title={title} description={description}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-12">
    <div>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Get a Free Quote</h1>
      <p class="mt-3 text-slate-600">
        Tell us what's going on and we'll get back to you shortly. For
        anything urgent, call us directly.
      </p>

      <div class="mt-8">
        <ContactForm />
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-xl border border-slate-200 p-6">
        <h2 class="font-semibold text-slate-900 mb-3">Contact Details</h2>
        <ul class="space-y-2 text-sm text-slate-600">
          <li>
            <a href={`tel:${site.phone}`} class="hover:text-[var(--brand)]">{site.phoneDisplay}</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="hover:text-[var(--brand)]">{site.email}</a>
          </li>
          <li>{site.address}</li>
        </ul>
      </div>

      <div class="rounded-xl border border-slate-200 overflow-hidden">
        <iframe
          title={`Map showing ${site.business} location`}
          width="100%"
          height="280"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src={`https://www.google.com/maps?q=${mapsQuery}&output=embed`}
        ></iframe>
      </div>

      <div class="rounded-xl border border-slate-200 p-6">
        <h2 class="font-semibold text-slate-900 mb-2">Service Areas</h2>
        <p class="text-sm text-slate-600">{site.serviceAreas.join(" \u00B7 ")}</p>
      </div>
    </div>
  </section>
</Base>
