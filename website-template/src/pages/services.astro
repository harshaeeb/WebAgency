---
// src/pages/services.astro
import Base from "../layouts/Base.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { site } from "../config/site";

const title = `Plumbing Services | ${site.business}`;
const description = `${site.services.map(s => s.name).join(", ")} for ${site.serviceAreas.join(", ")}. Call ${site.phoneDisplay} for a free quote.`;
---

<Base title={title} description={description}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Our Services</h1>
      <p class="mt-3 text-slate-600">
        Serving {site.serviceAreas.join(", ")} for {site.yearsInBusiness}+ years.
      </p>
    </div>
  </section>
  <ServicesGrid />
</Base>
