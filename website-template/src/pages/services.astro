---
// src/pages/services.astro
import Base from "../layouts/Base.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { site } from "../config/site";

const title = `Pet Grooming & Boarding Services | ${site.business} | ${site.city}, ${site.state}`;
const description = `${site.services.map(s => s.name).join(", ")} for families in ${site.serviceAreas.join(", ")}. Call ${site.phoneDisplay} to book.`;
---

<Base title={title} description={description}>
  <section class="border-b" style="background: var(--brand-50); border-color: var(--brand-100);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-14 text-center" data-reveal>
      <span class="inline-block text-xs font-bold uppercase tracking-widest mb-3 rounded-full px-3 py-1 border" style="color: var(--brand-700); background: var(--brand-100); border-color: var(--brand-200);">What We Offer</span>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Our Pet Care Services</h1>
      <p class="mt-3 text-slate-600 max-w-xl mx-auto">
        Grooming, boarding, daycare, and more — serving {site.serviceAreas.join(", ")} for {site.yearsInBusiness}+ years.
      </p>
    </div>
  </section>
  <ServicesGrid hideHeading />
</Base>
