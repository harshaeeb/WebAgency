---
// src/pages/services/[slug].astro
//
// Generates one dedicated, statically-built page per entry in
// site.services — per the SEO checklist in CLAUDE.md, services are never
// combined onto a single generic page. Adding a new service to site.ts
// automatically creates its page; no other file needs to change.
import Base from "../../layouts/Base.astro";
import ClickToCall from "../../components/ClickToCall.astro";
import ContactForm from "../../components/ContactForm.astro";
import { site } from "../../config/site";
import { resolveImage } from "../../utils/resolveImage";

export function getStaticPaths() {
  return site.services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const title = `${service.name} in ${site.city}, ${site.state} | ${site.business}`;
const description = service.shortDescription;
const serviceImage = resolveImage(service.image);
---

<Base title={title} description={description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-start">
    <div>
      <p class="text-sm font-medium text-[var(--brand-700)]">{site.business}</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-slate-900">{service.name}</h1>
      <p class="mt-4 text-lg text-slate-600">{service.description}</p>

      <p class="mt-4 text-sm text-slate-500">
        Proudly serving {site.serviceAreas.join(", ")}.
      </p>

      <div class="mt-8">
        <ClickToCall label={`Call about ${service.name}`} />
      </div>
    </div>

    {serviceImage ? (
      <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lg shadow-[var(--brand-100)] ring-1 ring-slate-900/5">
        <img
          src={serviceImage}
          alt={service.name}
          class="w-full h-full object-cover"
          width="640"
          height="480"
        />
      </div>
    ) : (
      <div class="aspect-[4/3] rounded-2xl bg-[var(--brand-50)] border border-[var(--brand-100)] flex items-center justify-center text-[var(--brand-400)] text-sm">
        [ {service.name} image goes here ]
      </div>
    )}
  </section>

  <section class="bg-[var(--brand-50)] border-t border-[var(--brand-100)]">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Request a Quote</h2>
      <ContactForm />
    </div>
  </section>
</Base>
