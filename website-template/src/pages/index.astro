---
// src/pages/index.astro
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import ReviewsWidget from "../components/ReviewsWidget.astro";
import BookingEmbed from "../components/BookingEmbed.astro";
import { site } from "../config/site";

const title = `${site.business} | Pet Grooming & Boarding in ${site.city}, ${site.state}`;
const description = `${site.business} offers ${site.services.map(s => s.name.toLowerCase()).join(", ")} for families in ${site.serviceAreas.join(", ")}. ${site.yearsInBusiness}+ years of professional pet care, ${site.googleRating}-star rated.`;
---

<Base title={title} description={description}>
  <Hero />
  <ServicesGrid compact />
  <ReviewsWidget />
  <BookingEmbed />
</Base>
