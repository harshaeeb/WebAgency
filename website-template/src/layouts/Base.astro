---
// src/layouts/Base.astro
//
// Every page wraps in this layout. LocalBusiness schema markup lives here,
// populated entirely from site.ts, per the SEO checklist in CLAUDE.md.
import "../styles/global.css";
import { site } from "../config/site";
import { generateBrandCssVars } from "../utils/palette";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;          // full page title, already formatted per the SEO checklist
  description: string;    // meta description, 1-2 plain sentences
}

const { title, description } = Astro.props;

// Derives the full brand-50 through brand-950 tonal scale (plus a couple of
// semantic aliases) from site.brandColor at build time. See
// src/utils/palette.ts for the color math; changing brandColor in site.ts
// is the only thing needed to re-theme every page.
const brandVars = generateBrandCssVars(site.brandColor);

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.business,
  telephone: site.phone,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.split(",")[0]?.trim(),
    addressLocality: site.city,
    addressRegion: site.state,
    postalCode: site.zip,
    addressCountry: "US",
  },
  areaServed: site.serviceAreas,
  aggregateRating: site.googleReviewCount
    ? {
        "@type": "AggregateRating",
        ratingValue: site.googleRating,
        reviewCount: site.googleReviewCount,
      }
    : undefined,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- NAP consistency: same business name/phone/address format everywhere -->
    <meta name="author" content={site.business} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />

    <style define:vars={brandVars}>
      :root {
        --brand-50: var(--brand50);
        --brand-100: var(--brand100);
        --brand-200: var(--brand200);
        --brand-300: var(--brand300);
        --brand-400: var(--brand400);
        --brand-500: var(--brand500);
        --brand-600: var(--brand600);
        --brand-700: var(--brand700);
        --brand-800: var(--brand800);
        --brand-900: var(--brand900);
        --brand-950: var(--brand950);
        /* Semantic aliases used directly in components: */
        --brand: var(--brand600);             /* primary action color (buttons, links) */
        --brand-dark: var(--brand800);         /* hover/active states */
        --brand-surface: var(--brand50);       /* tinted section backgrounds */
        --brand-surface-strong: var(--brand100);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col font-sans text-slate-800 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
