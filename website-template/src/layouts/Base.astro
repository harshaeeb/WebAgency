---
// src/layouts/Base.astro
//
// Every page wraps in this layout. LocalBusiness schema markup lives here,
// populated entirely from site.ts, per the SEO checklist in CLAUDE.md.
import "../styles/global.css";
import { site, validateConfig } from "../config/site";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Fail loudly at build/dev time if the config is incomplete or still
// contains placeholder values — catches misconfigurations before they reach prod.
validateConfig(site);

interface Props {
  title: string;          // full page title, already formatted per the SEO checklist
  description: string;    // meta description, 1-2 plain sentences
  ogImage?: string;       // optional absolute URL for og:image social preview
}

const { title, description, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, site.url).href;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.business,
  telephone: site.phone,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.split(",")[0]?.trim(),
    addressLocality: site.city,
    addressRegion: site.state,
    postalCode: site.zip,
    addressCountry: "US",
  },
  areaServed: site.serviceAreas,
  aggregateRating: site.googleReviewCount
    ? {
        "@type": "AggregateRating",
        ratingValue: site.googleRating,
        reviewCount: site.googleReviewCount,
      }
    : undefined,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- NAP consistency: same business name/phone/address format everywhere -->
    <meta name="author" content={site.business} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />

    <style define:vars={{ brandColor: site.brandColor }}>
      :root {
        --brand: var(--brandColor);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col font-sans text-slate-800 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // Scroll-reveal: watches [data-reveal] and [data-reveal-stagger] elements
      // and adds .is-visible once they enter the viewport.
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } }),
        { threshold: 0.12 }
      );
      document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach(el => observer.observe(el));

      // Count-up: animates [data-countup] from 0 to its text value on reveal.
      const countObserver = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target;
          const target = parseInt(el.textContent ?? '0', 10);
          const duration = 1400;
          const start = performance.now();
          const tick = (now) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(eased * target).toString();
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          countObserver.unobserve(el);
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-countup]').forEach(el => countObserver.observe(el));
    </script>
  </body>
</html>
